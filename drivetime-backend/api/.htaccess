RewriteEngine On

# Allow CORS
Header set Access-Control-Allow-Origin "*"
Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
Header set Access-Control-Allow-Headers "Content-Type, Authorization"

# Handle Options method (Preflight)
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route all API requests to the corresponding PHP file
# RewriteRule ^instructors/?$ instructors.php [L]
# RewriteRule ^bookings/?$ bookings.php [L]
# RewriteRule ^availability/?$ availability.php [L]
