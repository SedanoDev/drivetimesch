# Enable Apache modules if not already enabled (handled by Dockerfile)
# <IfModule mod_rewrite.c>
#     RewriteEngine On
# </IfModule>

# Ensure CORS headers are sent even on 500 errors
<IfModule mod_headers.c>
    # Note: Apache might not know HTTP_ORIGIN dynamically in .htaccess easily without mod_rewrite tricks
    # For dev, we can set * or verify origin.
    # But PHP handles it better. This is just a backup.
    # Header set Access-Control-Allow-Origin "*"
</IfModule>
